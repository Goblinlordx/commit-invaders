{
  "name": "commit-invaders",
  "version": "0.1.0",
  "description": "A GitHub Action that generates animated SVG of a Space Invaders-style game from your contribution graph",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "dev:sim": "vite dev/sim-viewer",
    "dev:entities": "vite dev/entity-test"
  },
  "keywords": [
    "github",
    "action",
    "contribution-graph",
    "space-invaders",
    "svg",
    "animation"
  ],
  "license": "MIT",
  "devDependencies": {
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@octokit/graphql": "^9.0.3"
  }
}
